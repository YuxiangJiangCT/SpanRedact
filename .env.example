# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# The real .env is gitignored and must never be committed.

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
# Requires a funded account (minimum $5 top-up to use the API).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Where to send traces. Matches the Jaeger OTLP gRPC port from
# examples/docker-compose.yml. Leave as-is for the local demo.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
